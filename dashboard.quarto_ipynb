      "source": [
        "---\n",
        "title: \"VitalDB — Exploratory Analysis\"\n",
        "format:\n",
        "  dashboard:\n",
        "    orientation: rows\n",
        "jupyter: python3\n",
        "execute:\n",
        "  echo: false\n",
        "  warning: false\n",
        "  message: false\n",
